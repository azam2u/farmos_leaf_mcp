# ---- farmOS ----
FARMOS_HOST=https://try.farmos.net
FARMOS_USER=
FARMOS_PASSWORD=
FARMOS_CLIENT_ID=farm
FARMOS_CLIENT_SECRET=

# ---- YOLO ----
LEAF_YOLO_DIR=/home/cvl/farmos_yolo_model
LEAF_YOLO_MODEL_PATH=/home/cvl/farmos_yolo_model/weights/best.pt
LEAF_YOLO_INFER_SCRIPT=/home/cvl/farmos_yolo_model/infer_image.py
LEAF_YOLO_LIVE_PREVIEW_SCRIPT=/home/cvl/farmos_yolo_model/live_preview.py
LEAF_YOLO_CONFIDENCE=0.25
LEAF_YOLO_LIVE_PREVIEW_ON_ASK=1
LEAF_CAPTURE_LIVE_INFERENCE=1
LEAF_CAPTURE_LIVE_WINDOW_TITLE=FarmOS Capture Live Inference
LEAF_IDENTIFICATION_WINDOW_TITLE=FarmOS Identification Preview

# ---- Paths ----
LEAF_CAPTURE_DIR=./captures
MAPBOX_INPUT_DIR=./mapbox_inputs
SEGMENTED_DIR=./received_segmented_mapbox_image
LEAF_EXPORT_DIR=./plant_exports

# ---- Geometry / map image source ----
MAPBOX_TOKEN=
SEGMENT_SERVER_HOST=
SEGMENT_SERVER_PORT=5555
SEGMENT_SOCKS_PROXY=

# ---- Low-confidence remote review (ZeroMQ) ----
LOW_CONF_SERVER_HOST=
LOW_CONF_SERVER_PORT=5555
LOW_CONF_SOCKS_PROXY=
LOW_CONF_THRESHOLD_PERCENT=50.0
LOW_CONF_TIMEOUT_MS=20000

# ---- Camera/GPS ----
LEAF_CAMERA_LOCK_TIMEOUT_SECONDS=120
GPS_DEVICE=/dev/ttyACM0
GPS_READ_TIMEOUT_SECONDS=25

# ---- Automatic collection ----
AUTO_COORDINATE_SOURCE=dummy
AUTO_DUMMY_LATITUDE=35.009445
AUTO_DUMMY_LONGITUDE=135.718787
AUTO_DUMMY_MOVE_METERS_PER_CHECK=1.2
AUTO_MIN_MOVEMENT_METERS=1.0
AUTO_POLL_SECONDS=10
AUTO_MAX_RUNS=0
AUTO_CAMERA_INDEX=0
AUTO_CLASSIFIER_DELAY_SECONDS=5
AUTO_COLLECTION_INTERVAL_SECONDS=3
AUTO_COLLECTION_DURATION_SECONDS=15
AUTO_MAPBOX_ZOOM=18
AUTO_MAPBOX_WIDTH=800
AUTO_MAPBOX_HEIGHT=800
AUTO_UPLOAD_TO_ACTIVITY_LOG=1
AUTO_JOB_DATABASE=./collection_jobs/jobs.sqlite3
AUTO_JOB_LIST_LIMIT=20
AUTO_RUNNER_LOCK_PATH=/tmp/farmos_leaf_auto_collect.lock

# ---- Optional formatting ----
LEAF_NOTES_HTML_FORMAT=default
GOOGLE_MAPS_API_KEY=

# ---- Export request cache TTL (seconds) ----
LEAF_EXPORT_SELECTION_TTL_SECONDS=1800
